{
  "manifest_version": 3,
  "name": "GBrain Capture",
  "version": "0.1.0",
  "description": "Capture web content into your GBrain knowledge base",
  "permissions": ["storage", "alarms", "activeTab", "scripting"],
  "host_permissions": ["http://localhost:19285/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "commands": {
    "capture-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Capture current page to GBrain"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://read.amazon.com/notebook*"],
      "js": ["kindle-content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
